<UserControl
    x:Class="Skua.WPF.UserControls.CBOClassSelectUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Skua.WPF.UserControls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <GroupBox
            Grid.Column="0"
            Margin="0,0,3,0"
            Header="Solo Class">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,3">
                    <ComboBox
                        x:Name="SoloClassComboBox"
                        DropDownOpened="ClassComboBox_DropDownOpened"
                        materialDesign:HintAssist.Hint="Class"
                        ItemsSource="{Binding PlayerClasses}"
                        SelectedItem="{Binding SelectedSoloClass}" />
                </DockPanel>
                <ComboBox
                    Grid.Row="1"
                    Height="32"
                    Margin="0,3"
                    materialDesign:HintAssist.Hint="Mode"
                    ItemsSource="{Binding SoloModeStrings}"
                    SelectedItem="{Binding SelectedSoloModeString}" />
                <CheckBox
                    Grid.Row="2"
                    HorizontalAlignment="Stretch"
                    Content="Specify Equipment"
                    IsChecked="{Binding UseSoloEquipment}"
                    Style="{StaticResource MaterialDesignFilterChipPrimaryCheckBox}" />
            </Grid>
        </GroupBox>
        <GroupBox
            Grid.Column="1"
            Margin="3,0,0,0"
            Header="Farm Class">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,3">
                    <ComboBox
                        x:Name="FarmClassComboBox"
                        DropDownOpened="ClassComboBox_DropDownOpened"
                        materialDesign:HintAssist.Hint="Class"
                        ItemsSource="{Binding PlayerClasses}"
                        SelectedItem="{Binding SelectedFarmClass}" />
                </DockPanel>
                <ComboBox
                    Grid.Row="1"
                    Height="32"
                    Margin="0,3"
                    materialDesign:HintAssist.Hint="Mode"
                    ItemsSource="{Binding FarmModeStrings}"
                    SelectedItem="{Binding SelectedFarmModeString}" />
                <CheckBox
                    Grid.Row="2"
                    HorizontalAlignment="Stretch"
                    Content="Specify Equipment"
                    IsChecked="{Binding UseFarmEquipment}"
                    Style="{StaticResource MaterialDesignFilterChipPrimaryCheckBox}" />
            </Grid>
        </GroupBox>
        <GroupBox
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,6,3,0"
            Header="Dodge Class">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,3">
                    <ComboBox
                        x:Name="DodgeClassComboBox"
                        DropDownOpened="ClassComboBox_DropDownOpened"
                        materialDesign:HintAssist.Hint="Class"
                        ItemsSource="{Binding PlayerClasses}"
                        SelectedItem="{Binding SelectedDodgeClass}" />
                </DockPanel>
                <ComboBox
                    Grid.Row="1"
                    Height="32"
                    Margin="0,3"
                    materialDesign:HintAssist.Hint="Mode"
                    ItemsSource="{Binding DodgeModeStrings}"
                    SelectedItem="{Binding SelectedDodgeModeString}" />
                <CheckBox
                    Grid.Row="2"
                    HorizontalAlignment="Stretch"
                    Content="Specify Equipment"
                    IsChecked="{Binding UseDodgeEquipment}"
                    Style="{StaticResource MaterialDesignFilterChipPrimaryCheckBox}" />
            </Grid>
        </GroupBox>
        <GroupBox
            Grid.Row="1"
            Grid.Column="1"
            Margin="3,6,0,0"
            Header="Boss Class">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,3">
                    <ComboBox
                        x:Name="BossClassComboBox"
                        DropDownOpened="ClassComboBox_DropDownOpened"
                        materialDesign:HintAssist.Hint="Class"
                        ItemsSource="{Binding PlayerClasses}"
                        SelectedItem="{Binding SelectedBossClass}" />
                </DockPanel>
                <ComboBox
                    Grid.Row="1"
                    Height="32"
                    Margin="0,3"
                    materialDesign:HintAssist.Hint="Mode"
                    ItemsSource="{Binding BossModeStrings}"
                    SelectedItem="{Binding SelectedBossModeString}" />
                <CheckBox
                    Grid.Row="2"
                    HorizontalAlignment="Stretch"
                    Content="Specify Equipment"
                    IsChecked="{Binding UseBossEquipment}"
                    Style="{StaticResource MaterialDesignFilterChipPrimaryCheckBox}" />
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
